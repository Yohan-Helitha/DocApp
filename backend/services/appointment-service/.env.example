NODE_ENV=development
PORT=4003

# Individual connection vars (used for local dev without Docker)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your-postgres-password
PGDATABASE=appointmentsdb

# Full connection string — used inside Docker (hostname = docker service name "appointments-postgres")
DATABASE_URL=postgresql://postgres:your-postgres-password@appointments-postgres:5432/appointmentsdb

# Must be the SAME value as JWT_SECRET in auth-service — tokens are verified locally using this secret
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-production

# Inter-service URLs — use Docker service names as hostnames when running in Docker
DOCTOR_SERVICE_URL=http://doctor-management-service:4002
NOTIFICATION_SERVICE_URL=http://notification-service:6000

LOG_LEVEL=debug
