NODE_ENV=development
PORT=4001

# Postgres connection (used if DATABASE_URL is empty)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=authdb

# Or set a single DATABASE_URL value
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/authdb

JWT_SECRET=8f3d2c1b9e7a6c5b4d3f2a1e0b9c8d7f6a5e4d3c2b1a0f9e8d7c6b5a4e3f2d1
BCRYPT_SALT_ROUNDS=10
LOG_LEVEL=debug
