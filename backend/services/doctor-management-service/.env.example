NODE_ENV=development
PORT=4002

# Individual connection vars (used for local dev without Docker)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your-postgres-password
PGDATABASE=doctorsdb

# Full connection string — used inside Docker (hostname = docker service name "doctors-postgres")
DATABASE_URL=postgresql://postgres:your-postgres-password@doctors-postgres:5432/doctorsdb

# HS256 secret used ONLY for service-to-service tokens (e.g. appointment-service -> doctor-management-service)
# If you're running locally, keep this the SAME across doctor-management-service and appointment-service.
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-production

# Public key used to verify RS256 access tokens issued by auth-service
AUTH_PUBLIC_KEY_PATH=../auth-service/keys/public.pem

LOG_LEVEL=debug
